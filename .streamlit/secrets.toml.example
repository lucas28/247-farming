# Copie para secrets.toml (local) ou Streamlit Cloud → Secrets.
# NÃO use o wizard Next.js do Supabase (npm / @supabase/ssr) — este app é Python/Streamlit.

admin_pin = "altere_este_pin"

# --- Opção A: connection string (senha SEM @ # ! % ou use URL-encoding) ---
# Supabase → Connect → Connection pooling → Transaction (6543) ou Session (5432)
# Host: *.pooler.supabase.com  |  Usuário: postgres.cugzgfbbtugeleotqwuc
#
# DATABASE_URL = "postgresql://postgres.cugzgfbbtugeleotqwuc:SUA_SENHA@aws-1-us-west-2.pooler.supabase.com:6543/postgres"

# --- Opção B: campos separados (recomendado) ---
# Supabase → Connect → Transaction pooler
# DB_HOST = "aws-1-us-west-2.pooler.supabase.com"
# DB_PORT = 6543
# DB_USER = "postgres.cugzgfbbtugeleotqwuc"
# DB_PASSWORD = "sua_senha_aqui"
# DB_NAME = "postgres"
