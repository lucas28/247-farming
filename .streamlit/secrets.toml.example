# Copie para secrets.toml (local) ou Streamlit Cloud → Secrets.
# NÃO use o wizard Next.js do Supabase (npm / @supabase/ssr) — este app é Python/Streamlit.

admin_pin = "altere_este_pin"

# Supabase → botão Connect → Connection pooling → Transaction (porta 6543)
# NÃO use db.*.supabase.co:5432 no Streamlit Cloud (só IPv6).
# Substitua [SENHA] e confira host/região no painel do Supabase.
#
# DATABASE_URL = "postgresql://postgres.cugzgfbbtugeleotqwuc:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres"

# NEXT_PUBLIC_SUPABASE_URL e publishable key NÃO são usados por este app.
# Só a DATABASE_URL (Postgres) acima.
