# Copie este arquivo para secrets.toml e ajuste o PIN da liderança.
# O arquivo secrets.toml não deve ser commitado (está no .gitignore).
#
# Deploy (Streamlit Cloud): configure em Settings → Secrets:
#   admin_pin = "seu_pin_forte"
#
# Sem admin_pin, Líder/Vice não conseguem entrar como admin.

admin_pin = "altere_este_pin"
